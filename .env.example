# ── Required ──────────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional: Email sending via Gmail ─────────────────────────────────────────
# Use a Gmail App Password (not your real password)
# Enable at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_gmail@gmail.com
GMAIL_APP_PASS=your_16_char_app_password

# ── Optional: Google Calendar integration ─────────────────────────────────────
# Download credentials.json from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Enable "Google Calendar API" and create OAuth 2.0 Desktop credentials
# Then place credentials.json in this folder — the app will handle auth on first run
